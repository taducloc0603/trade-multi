<Window x:Class="TradeDesktop.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:views="clr-namespace:TradeDesktop.App.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Trade Desktop Dashboard"
        Height="790"
        Width="1240"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6FA">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="IosToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    CornerRadius="12"
                                    Background="#D0D5DD"
                                    BorderBrush="#C8CDD4"
                                    BorderThickness="1" />

                            <Ellipse x:Name="Thumb"
                                     Width="20"
                                     Height="20"
                                     Fill="White"
                                     Stroke="#D0D5DD"
                                     StrokeThickness="1"
                                     HorizontalAlignment="Left"
                                     Margin="2,0,0,0"
                                     VerticalAlignment="Center" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#12B76A" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#12B76A" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.55" />
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="1.1*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="12" Padding="12" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Dashboard" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#B42318"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding IsDbInlineDataVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding DbInlineData}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#B42318"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding IsConfigErrorVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding ConfigErrorMessage}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Start"
                            Width="68"
                            Height="36"
                            Margin="0,0,8,0"
                            Command="{Binding StartTradingLogicCommand}" />
                    <Button Content="Stop"
                            Width="68"
                            Height="36"
                            Margin="0,0,8,0"
                            Command="{Binding StopTradingLogicCommand}" />
                    <Button Content="Log Folder"
                            Width="90"
                            Height="36"
                            Margin="0,0,8,0"
                            Command="{Binding OpenLogFolderCommand}" />
                    <Button Content="Current Log"
                            Width="96"
                            Height="36"
                            Margin="0,0,8,0"
                            Command="{Binding OpenCurrentLogCommand}" />
                    <TextBox Width="170"
                             Height="36"
                             Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             IsReadOnly="True"
                             Text="{Binding MachineHostName, Mode=OneWay}" />
                    <Button Content="Copy Host"
                            Width="84"
                            Height="36"
                            Margin="0,0,8,0"
                            Command="{Binding CopyHostNameCommand}" />
                    <Button Content="Reconnect"
                            Width="96"
                            Height="36"
                            Margin="0,0,8,0"
                            Command="{Binding ReconnectConfigCommand}" />
                    <Button Content="Config"
                            Width="82"
                            Height="36"
                            Visibility="{Binding IsShowConfigVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding OpenConfigCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="12" Padding="12" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Thông số" FontSize="18" FontWeight="SemiBold" />

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Thông số" FontWeight="SemiBold" Foreground="#344054" />
                            <TextBlock Grid.Column="1" Text="{Binding ExchangeAHeader}" FontWeight="SemiBold" Foreground="#344054" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding ExchangeBHeader}" FontWeight="SemiBold" Foreground="#344054" HorizontalAlignment="Center" />

                            <Grid Grid.Row="2" Grid.ColumnSpan="3">
                                <Grid.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </Grid.Resources>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="0,5" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Symbol" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeASymbol}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBSymbol}" HorizontalAlignment="Center"/></Grid></Border>
                                <Border Grid.Row="1" Padding="0,5" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Bid" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeABid}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBBid}" HorizontalAlignment="Center"/></Grid></Border>
                                <Border Grid.Row="2" Padding="0,5" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Ask" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeAAsk}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBAsk}" HorizontalAlignment="Center"/></Grid></Border>
                                <Border Grid.Row="3" Padding="0,5" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Spread" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeASpread}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBSpread}" HorizontalAlignment="Center"/></Grid></Border>
                                <Border Grid.Row="4" Padding="0,5" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Latency(ms)" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeALatencyMs}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBLatencyMs}" HorizontalAlignment="Center"/></Grid></Border>
                                <Border Grid.Row="5" Padding="0,5" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="TPS" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeATps}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBTps}" HorizontalAlignment="Center"/></Grid></Border>
                                <Border Grid.Row="6" Padding="0,5" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Time" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeATime}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBTime}" HorizontalAlignment="Center"/></Grid></Border>
                                <Border Grid.Row="7" Padding="0,5" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Max Lat(ms)" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeAMaxLatMs}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBMaxLatMs}" HorizontalAlignment="Center"/></Grid></Border>
                                <Border Grid.Row="8" Padding="0,5" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Avg Lat(ms)" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeAAvgLatMs}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBAvgLatMs}" HorizontalAlignment="Center"/></Grid></Border>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="GAP BUY" FontWeight="SemiBold" Foreground="#344054" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding GapBuy}" Foreground="#101828" VerticalAlignment="Center" />

                            <TextBlock Grid.Column="4" Text="GAP SELL" FontWeight="SemiBold" Foreground="#344054" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="6" Text="{Binding GapSell}" Foreground="#101828" VerticalAlignment="Center" />

                            <Button Grid.Column="8"
                                    Content="BUY"
                                    Width="68"
                                    Height="30"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Background="#D92D20"
                                    BorderBrush="#D92D20"
                                    BorderThickness="1"
                                    Visibility="{Binding HasManualTradeHwndConfig, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding BuyCommand}" />

                            <Button Grid.Column="10"
                                    Content="SELL"
                                    Width="68"
                                    Height="30"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Background="#12B76A"
                                    BorderBrush="#12B76A"
                                    BorderThickness="1"
                                    Visibility="{Binding HasManualTradeHwndConfig, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding SellCommand}" />

                            <Button Grid.Column="12"
                                    Content="CLOSE"
                                    Width="68"
                                    Height="30"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Background="#667085"
                                    BorderBrush="#667085"
                                    BorderThickness="1"
                                    Visibility="{Binding HasManualTradeHwndConfig, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding CloseOrderCommand}" />
                        </Grid>

                        <TextBlock Grid.Row="6"
                                   Foreground="#667085"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding IsManualTradeWarningVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Text="{Binding ManualTradeWarningMessage}" />
                    </Grid>
            </Border>

            <Border Grid.Column="2" CornerRadius="12" Padding="12" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Trading Signal" FontSize="18" FontWeight="SemiBold" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="Open Gap Buy" VerticalAlignment="Center" Foreground="#344054" Margin="0,0,6,0" />
                            <ToggleButton Width="46"
                                          Height="24"
                                          Margin="0,0,16,0"
                                          Style="{StaticResource IosToggleStyle}"
                                          IsChecked="{Binding IsOpenGapBuyEnabled, Mode=TwoWay}" />

                            <TextBlock Text="Open Gap Sell" VerticalAlignment="Center" Foreground="#344054" Margin="0,0,6,0" />
                            <ToggleButton Width="46"
                                          Height="24"
                                          Style="{StaticResource IosToggleStyle}"
                                          IsChecked="{Binding IsOpenGapSellEnabled, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" BorderBrush="#EEF1F5" BorderThickness="1" CornerRadius="8" Padding="12" Background="#FAFBFC">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock FontWeight="SemiBold" Foreground="#344054">
                                <Run Text="Trading Logic Status: " />
                                <Run Text="{Binding TradingLogicStatusText, Mode=OneWay}" Foreground="{Binding TradingLogicStatusBrush, Mode=OneWay}" />
                            </TextBlock>

                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <TextBlock Text="Last Signal: " FontWeight="SemiBold" Foreground="#344054" />
                                <TextBlock Text="{Binding LastSignalText, Mode=OneWay}" Foreground="#101828" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Orientation="Horizontal">
                                <TextBlock Text="Current Position: " FontWeight="SemiBold" Foreground="#344054" />
                                <TextBlock Text="{Binding CurrentPositionText, Mode=OneWay}" Foreground="#101828" />
                            </StackPanel>

                            <StackPanel Grid.Row="6" Orientation="Horizontal">
                                <TextBlock Text="Current Phase: " FontWeight="SemiBold" Foreground="#344054" />
                                <TextBlock Text="{Binding CurrentPhaseText, Mode=OneWay}" Foreground="#101828" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="6" BorderBrush="#EEF1F5" BorderThickness="1" CornerRadius="8" Padding="10" Background="#FAFBFC">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Signal Logs" FontWeight="SemiBold" Foreground="#344054" />

                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding SignalLogItems}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="#101828"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4" CornerRadius="12" Padding="12" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0"
                            SelectedIndex="{Binding SelectedOrderTabIndex, Mode=TwoWay}">
                    <TabItem Header="{Binding TradeTab.TabHeader}">
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="0.4*" />
                            </Grid.ColumnDefinitions>

                            <views:OrderInfoPanel Grid.Column="0" DataContext="{Binding TradeTab.LeftPanel}" />
                            <views:OrderInfoPanel Grid.Column="2" DataContext="{Binding TradeTab.RightPanel}" />

                            <Border Grid.Column="4"
                                    CornerRadius="10"
                                    Padding="10"
                                    Background="#FAFBFC"
                                    BorderBrush="#EEF1F5"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Profit Realtime (A + B)"
                                               FontWeight="SemiBold"
                                               Foreground="#344054" />

                                    <Border Grid.Row="2"
                                            BorderBrush="#E4E7EC"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Background="White"
                                            Padding="8">
                                        <Border BorderBrush="#EEF1F5"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="6"
                                                Background="#FAFBFC">
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Auto">
                                                <DataGrid ItemsSource="{Binding TradeRealtimeProfitRows}"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          CanUserReorderColumns="False"
                                                          CanUserResizeRows="False"
                                                          CanUserSortColumns="False"
                                                          EnableColumnVirtualization="False"
                                                          EnableRowVirtualization="False"
                                                          HeadersVisibility="Column"
                                                          GridLinesVisibility="Horizontal"
                                                          RowHeaderWidth="0"
                                                          BorderThickness="0"
                                                          Background="Transparent"
                                                          Foreground="#101828"
                                                          FontFamily="Consolas"
                                                          FontSize="11"
                                                          MinHeight="48"
                                                          ScrollViewer.CanContentScroll="False"
                                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                          ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                                    <DataGrid.ColumnHeaderStyle>
                                                        <Style TargetType="DataGridColumnHeader">
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                            <Setter Property="Foreground" Value="#475467" />
                                                            <Setter Property="Background" Value="#FAFBFC" />
                                                        </Style>
                                                    </DataGrid.ColumnHeaderStyle>

                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="STT" Binding="{Binding Stt}" Width="55" />
                                                        <DataGridTextColumn Header="Profit realtime" Binding="{Binding ProfitRealtime}" Width="120" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </ScrollViewer>
                                        </Border>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="{Binding HistoryTab.TabHeader}">
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="0.4*" />
                            </Grid.ColumnDefinitions>

                            <views:OrderInfoPanel Grid.Column="0" DataContext="{Binding HistoryTab.LeftPanel}" />
                            <views:OrderInfoPanel Grid.Column="2" DataContext="{Binding HistoryTab.RightPanel}" />

                            <Border Grid.Column="4"
                                    CornerRadius="10"
                                    Padding="10"
                                    Background="#FAFBFC"
                                    BorderBrush="#EEF1F5"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Profit Realtime (A + B)"
                                                   FontWeight="SemiBold"
                                                   Foreground="#344054" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding HistoryRealtimeProfitSummary}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#344054"
                                                   HorizontalAlignment="Right" />
                                    </Grid>

                                    <Border Grid.Row="2"
                                            BorderBrush="#E4E7EC"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Background="White"
                                            Padding="8">
                                        <Border BorderBrush="#EEF1F5"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="6"
                                                Background="#FAFBFC">
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Auto">
                                                <DataGrid ItemsSource="{Binding HistoryRealtimeProfitRows}"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          CanUserReorderColumns="False"
                                                          CanUserResizeRows="False"
                                                          CanUserSortColumns="False"
                                                          EnableColumnVirtualization="False"
                                                          EnableRowVirtualization="False"
                                                          HeadersVisibility="Column"
                                                          GridLinesVisibility="Horizontal"
                                                          RowHeaderWidth="0"
                                                          BorderThickness="0"
                                                          Background="Transparent"
                                                          Foreground="#101828"
                                                          FontFamily="Consolas"
                                                          FontSize="11"
                                                          MinHeight="48"
                                                          ScrollViewer.CanContentScroll="False"
                                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                          ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                                    <DataGrid.ColumnHeaderStyle>
                                                        <Style TargetType="DataGridColumnHeader">
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                            <Setter Property="Foreground" Value="#475467" />
                                                            <Setter Property="Background" Value="#FAFBFC" />
                                                        </Style>
                                                    </DataGrid.ColumnHeaderStyle>

                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="STT" Binding="{Binding Stt}" Width="55" />
                                                        <DataGridTextColumn Header="Profit" Binding="{Binding Profit}" Width="95" />
                                                        <DataGridTextColumn Header="Profit ($)" Binding="{Binding ProfitDollar}" Width="95" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </ScrollViewer>
                                        </Border>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <Border Grid.RowSpan="5"
                CornerRadius="12"
                Background="#99000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="White" CornerRadius="10" Padding="20" BorderBrush="#D0D5DD" BorderThickness="1">
                    <StackPanel Width="280">
                        <TextBlock Text="Đang tải..." FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                        <ProgressBar Margin="0,12,0,0" IsIndeterminate="True" Height="6" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding LoadingMessage}"
                                   Foreground="#475467"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>